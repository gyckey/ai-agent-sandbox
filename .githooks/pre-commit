#!/usr/bin/env bash
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
cd "${REPO_ROOT}"

staged_shell_files=()
while IFS= read -r -d '' file; do
  if [[ "$file" == .clawdbot/scripts/*.sh ]]; then
    staged_shell_files+=("$file")
  fi
done < <(git diff --cached --name-only --diff-filter=ACMR -z)

if [[ ${#staged_shell_files[@]} -eq 0 ]]; then
  exit 0
fi

./.clawdbot/scripts/format-shell.sh

git add .clawdbot/scripts/*.sh

echo "[INFO] pre-commit: formatted and re-staged shell scripts"
